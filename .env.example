# ── App ───────────────────────────────────────────────────────────────────────
PROJECT_NAME="Pomodoro API"
SECRET_KEY="SUA_CHAVE_SECRETA_MUITO_SEGURA"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# ── Database ──────────────────────────────────────────────────────────────────
SQLALCHEMY_DATABASE_URI="sqlite:///../database/pomodoro.db"

# ── Ports (docker-compose) ────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000
OLLAMA_PORT=11434

# ── AI Module ─────────────────────────────────────────────────────────────────
# Provider: mock (no key needed) | openai | ollama
AI_PROVIDER=mock

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Whisper audio/video transcription
# Requires: pip install openai-whisper  +  ffmpeg on PATH
USE_WHISPER=false
WHISPER_MODEL=base

# LangChain orchestration
# Requires: pip install langchain langchain-openai  (or langchain-community for Ollama)
USE_LANGCHAIN=false

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL="http://localhost:8000/api"
